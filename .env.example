# Scene Intelligence — cấu hình mẫu (copy sang .env). KHÔNG commit .env thật.

# PostgreSQL (nguồn sự thật — AD-4). Dùng driver async psycopg.
DATABASE_URL=postgresql+psycopg://scene:scene@localhost:5432/scene_intelligence

# Media storage nội bộ (AD-23). Backend filesystem cho MVP.
MEDIA_BACKEND=filesystem
# Đường mount kho media (NAS/SAN cho kho thật, ổ local cho dev).
MEDIA_ROOT=./_data/media

# Môi trường chạy
API_ENV=dev
